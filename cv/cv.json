    {
      "titulo": "Proyectos Técnicos",
      "entradas": [
        {
          "incluir": true,
          "titulo": "TIO-PR — Chatbot Turístico Inteligente",
          "subtitulo": "Proyecto en equipo — UPRM",
          "fecha": "Diciembre 2025",
          "detalle": "Propuesta y prototipo de un chatbot turístico bilingüe (español/inglés) para el oeste de Puerto Rico (Porta del Sol). Diseño híbrido que combina reglas, inteligencia artificial e IA generativa para recomendar playas, atardeceres y comida local. Prototipo construido en Landbot.io con un flujo conversacional por bloques."
        },
        {
          "incluir": true,
          "titulo": "Modelo Predictivo de Cancelación de Clientes (Customer Churn)",
          "subtitulo": "Proyecto de aprendizaje automático en equipo — UPRM",
          "fecha": "2025",
          "detalle": "Predicción de cancelación de clientes usando el conjunto de datos IBM Telco. Comparación de seis modelos de clasificación: Regresión Logística, Árbol de Decisión, Random Forest, Naïve Bayes, SVM y Gradient Boosting. Random Forest obtuvo el mejor desempeño (~92.6% de exactitud). Preprocesamiento con one-hot encoding, normalización y muestreo estratificado; interpretabilidad de resultados con valores SHAP. Implementado en Python con scikit-learn."
        },
        {
          "incluir": true,
          "titulo": "LPSIMP — Analizadores Léxico y Sintáctico",
          "subtitulo": "Proyecto de compiladores en equipo — UPRM",
          "fecha": "Otoño 2025",
          "detalle": "Diseño e implementación de los analizadores léxico y sintáctico del lenguaje de programación LPSIMP. Analizador léxico construido con Flex y analizador sintáctico con Bison, en lenguaje C. Incluye gramática formal, definición de tokens, autómatas finitos deterministas y manejo de múltiples errores. Herramientas: MSYS2 y Visual Studio Code. (Curso COMP 4998)."
        }
      ]
